{
  "name": "fhir-validate-vscode",
  "displayName": "FHIR Validate",
  "description": "Real-time FHIR R4 resource validation for VSCode",
  "version": "0.1.0",
  "publisher": "fhir-validate",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Programming Languages"],
  "activationEvents": ["onLanguage:fhir-json", "onLanguage:json"],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fhir-json",
        "extensions": [".fhir.json"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "FHIR Validate",
      "properties": {
        "fhir-validate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable FHIR validation"
        },
        "fhir-validate.severity.unknownProperties": {
          "type": "string",
          "default": "warning",
          "enum": ["error", "warning", "info"],
          "description": "Severity level for unknown properties in FHIR resources"
        }
      }
    },
    "commands": [
      {
        "command": "fhir-validate.validateDocument",
        "title": "FHIR: Validate Document"
      },
      {
        "command": "fhir-validate.showResourceInfo",
        "title": "FHIR: Show Resource Info"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fhir-validate/core": "workspace:*",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
